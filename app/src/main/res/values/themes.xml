<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TownClap" parent="Theme.AppCompat.Light">>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorPrimary</item>
        <item name="colorSecondaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="fontFamily">@font/gilroy_regular</item>
        <item name="android:textColor">#9C9090</item>

        <!-- Status bar color. -->
        <item name="android:titleTextStyle">@style/AppTheme.ActionBar.Title</item>
        <item name="android:forceDarkAllowed">false</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="AppTheme.ActionBar.Title" parent="@style/TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="Theme.Intro" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorPrimary</item>
        <item name="colorSecondaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/black</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="fontFamily">@font/gilroy_regular</item>
        <item name="android:textColor">#AAAAAA</item>
        <item name="android:titleTextStyle">@style/AppTheme.ActionBar.Title</item>

        <item name="android:forceDarkAllowed">false</item>
        <!-- Customize your theme here. -->
    </style>
    <style name="myfont">
        <item name="fontFamily">@font/gilroy_medium</item>
    </style>
    <style name="myfont_bold">
        <item name="fontFamily">@font/gilroybold</item>
    </style>


</resources>